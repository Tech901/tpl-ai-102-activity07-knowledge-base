# AZURE_OPENAI_ENDPOINT accepts either form:
#   https://<your-resource>.openai.azure.com/                              (base URL, preferred)
#   https://<your-resource>.openai.azure.com/openai/deployments/<deploy>   (full deployment URL)
# The app normalizes either form via app/_azure_endpoint.py.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_AI_SEARCH_KEY=your-search-key-here
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
STUDENT_CORPUS_SEED=your-github-username
